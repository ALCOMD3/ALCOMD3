---
import "@/generated/beer-themed.css";
import { getRelativeLocaleUrl } from "astro:i18n";
import { defaultUiLocale, supportedUiLocales, uiLocaleToRouteLocale } from "@/data/i18n";
import { themeModeStorageKey, uiLocaleStorageKey } from "@/data/ui-preferences";

const defaultLanguageRoute = getRelativeLocaleUrl(uiLocaleToRouteLocale(defaultUiLocale), "");
const languageRouteMap = Object.fromEntries(
    supportedUiLocales.map((locale) => [locale, getRelativeLocaleUrl(uiLocaleToRouteLocale(locale), "")]),
);
const languageRedirectConfig = {
    defaultUiLocale,
    supportedUiLocales,
    languageRouteMap,
    themeModeStorageKey,
    uiLocaleStorageKey,
};
---

<!doctype html>
<html lang="en-US">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="robots" content="noindex, nofollow">
        <meta name="color-scheme" content="light dark">
        <title>ALCOMD3</title>
        <script is:inline type="application/json" id="language-redirect-config" set:html={JSON.stringify(languageRedirectConfig)} />
        <script is:inline>
            (() => {
                const configElement = document.getElementById("language-redirect-config");

                if (!configElement?.textContent) {
                    return;
                }

                const config = JSON.parse(configElement.textContent);
                const supportedLocales = Array.isArray(config.supportedUiLocales) ? config.supportedUiLocales : [];
                const root = document.documentElement;

                function normalizeUiLocale(locale) {
                    if (!locale) {
                        return null;
                    }

                    const normalized = String(locale)
                        .trim()
                        .replaceAll("_", "-")
                        .toLowerCase();

                    return supportedLocales.find((candidate) => candidate.toLowerCase() === normalized) || null;
                }

                function normalizeBrowserUiLocale(locale) {
                    const exactLocale = normalizeUiLocale(locale);

                    if (exactLocale || !locale) {
                        return exactLocale;
                    }

                    const normalized = String(locale)
                        .trim()
                        .replaceAll("_", "-")
                        .toLowerCase();

                    if (normalized.startsWith("zh-tw") || normalized.startsWith("zh-hk") || normalized.startsWith("zh-mo")) {
                        return normalizeUiLocale("zh-TW");
                    }

                    if (normalized.startsWith("zh")) {
                        return normalizeUiLocale("zh-CN");
                    }

                    if (normalized.startsWith("ja")) {
                        return normalizeUiLocale("ja-JP");
                    }

                    if (normalized.startsWith("en")) {
                        return normalizeUiLocale("en-US");
                    }

                    return null;
                }

                function getStoredLocale() {
                    try {
                        return localStorage.getItem(config.uiLocaleStorageKey);
                    } catch {
                        return null;
                    }
                }

                function getStoredThemeMode() {
                    try {
                        return localStorage.getItem(config.themeModeStorageKey);
                    } catch {
                        return null;
                    }
                }

                const storedThemeMode = getStoredThemeMode();
                const systemThemeMode = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
                const themeMode = ["light", "dark", "system"].includes(storedThemeMode) ? storedThemeMode : "system";
                const resolvedThemeMode = themeMode === "system" ? systemThemeMode : themeMode;
                const browserLocales = navigator.languages?.length ? navigator.languages : [navigator.language];
                const storedLocale = normalizeUiLocale(getStoredLocale());
                const browserLocale = browserLocales.map(normalizeBrowserUiLocale).find(Boolean);
                const uiLocale = storedLocale || browserLocale || normalizeUiLocale(config.defaultUiLocale) || config.defaultUiLocale;
                const targetRoute = config.languageRouteMap?.[uiLocale] || config.languageRouteMap?.[config.defaultUiLocale];

                root.dataset.themeMode = resolvedThemeMode;
                root.style.colorScheme = resolvedThemeMode;

                if (targetRoute && window.location.pathname !== targetRoute) {
                    window.location.replace(targetRoute);
                }
            })();
        </script>
        <noscript>
            <meta http-equiv="refresh" content={`0; url=${defaultLanguageRoute}`}>
        </noscript>
    </head>
    <body></body>
</html>
