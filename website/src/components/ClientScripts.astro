<script>
    import "beercss/dist/cdn/beer.min.js";
    import {
        getRouteLocaleFromPath,
        resolveUiPreferences,
        themeModeStorageKey,
        uiLocaleStorageKey,
        type ResolvedThemeMode,
        type ThemeModePreference,
    } from "@/data/ui-preferences";
    const languageOptions = document.querySelectorAll<HTMLElement>("[data-language]");
    const themeModeOptions = document.querySelectorAll<HTMLElement>("[data-theme-mode-value]");
    const themeModeQuery = window.matchMedia("(prefers-color-scheme: dark)");

    function registerServiceWorker() {
        if (!("serviceWorker" in navigator)) {
            return;
        }

        window.addEventListener("load", () => {
            navigator.serviceWorker.register("/sw.js").catch((error) => {
                console.error(error);
            });
        });
    }

    function getLocalStorageValue(key: string) {
        try {
            return localStorage.getItem(key);
        } catch {
            return null;
        }
    }

    function setLocalStorageValue(key: string, value: string) {
        try {
            localStorage.setItem(key, value);
        } catch {
            // Storage can be disabled in privacy modes; the current interaction still applies in memory.
        }
    }

    function getSystemThemeMode(): ResolvedThemeMode {
        return themeModeQuery.matches ? "dark" : "light";
    }

    function resolveCurrentPreferences(
        localThemeMode = getLocalStorageValue(themeModeStorageKey),
        localLocale = getLocalStorageValue(uiLocaleStorageKey),
    ) {
        return resolveUiPreferences({
            urlLocale: getRouteLocaleFromPath(window.location.pathname),
            localLocale,
            accountLocale: null,
            browserLocale: navigator.languages?.length ? navigator.languages : navigator.language,
            localThemeMode,
            accountThemeMode: null,
            systemThemeMode: getSystemThemeMode(),
            defaultThemeMode: "system",
        });
    }

    function applyResolvedThemeMode(themeMode: ResolvedThemeMode) {
        document.documentElement.dataset.themeMode = themeMode;
        document.documentElement.style.colorScheme = themeMode;

        if (document.body) {
            document.body.classList.remove("light", "dark");
            document.body.classList.add(themeMode);
        }
    }

    function applyThemeMode(themeMode: ThemeModePreference) {
        const preferences = resolveCurrentPreferences(themeMode);

        applyResolvedThemeMode(preferences.resolved_theme_mode);

        themeModeOptions.forEach((option) => {
            const isActive = option.dataset.themeModeValue === preferences.theme_mode;

            option.classList.toggle("active", isActive);
            option.setAttribute("aria-selected", String(isActive));
        });
    }

    function selectLanguage(option: HTMLElement) {
        const selectedUiLocale = option.dataset.uiLocale;
        const selectedRouteLocale = option.dataset.language;
        const targetRoute = option.dataset.route;

        if (!selectedUiLocale || !selectedRouteLocale || !targetRoute) {
            return;
        }

        const preferences = resolveUiPreferences({
            localLocale: selectedUiLocale,
            defaultThemeMode: "system",
        });

        setLocalStorageValue(uiLocaleStorageKey, preferences.ui_locale);

        if (getRouteLocaleFromPath(window.location.pathname) !== selectedRouteLocale) {
            window.location.href = targetRoute;
        }
    }

    function selectThemeMode(option: HTMLElement) {
        const selectedThemeMode = option.dataset.themeModeValue;

        if (!selectedThemeMode) {
            return;
        }

        const preferences = resolveCurrentPreferences(selectedThemeMode);

        setLocalStorageValue(themeModeStorageKey, preferences.theme_mode);
        applyThemeMode(preferences.theme_mode);
    }

    applyThemeMode(resolveCurrentPreferences().theme_mode);

    languageOptions.forEach((option) => {
        option.addEventListener("click", () => {
            selectLanguage(option);
        });
    });

    themeModeOptions.forEach((option) => {
        option.addEventListener("click", () => {
            selectThemeMode(option);
        });
    });

    themeModeQuery.addEventListener("change", () => {
        if (resolveCurrentPreferences().theme_mode === "system") {
            applyThemeMode("system");
        }
    });

    registerServiceWorker();
</script>
