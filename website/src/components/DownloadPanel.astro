---
import "@/styles/downloads.css";
import PlatformBrandIcon from "@/components/PlatformBrandIcon.astro";
import {
    siteConfig,
    type DownloadChannel,
    type DownloadPlatformKey,
    type LocaleContent,
} from "@/data/site";

type Props = {
    locale: LocaleContent;
};

type CatalogDownload = {
    id: string;
    format: string;
    assetName: string;
    primary: boolean;
    url: string | null;
};

type CatalogPlatform = {
    key: string;
    operatingSystem: string;
    available: boolean;
    downloads: CatalogDownload[];
};

type DownloadCatalog = {
    channel: DownloadChannel;
    version: string;
    releaseUrl: string;
    platforms: CatalogPlatform[];
    hasDownloads: boolean;
    releasePageOnly: boolean;
};

const { locale } = Astro.props;
const content = locale.downloads;

function formatMessage(template: string, values: Record<string, string>) {
    return Object.entries(values).reduce(
        (message, [key, value]) => message.replaceAll(`{${key}}`, value),
        template,
    );
}

const catalogs = (siteConfig.downloadChannels as DownloadCatalog[]).map((catalog) => {
    const channelContent = content.channels[catalog.channel];
    if (!channelContent) {
        throw new Error(`Missing localized website download channel content for ${catalog.channel}`);
    }

    const platforms = catalog.platforms.map((platform) => {
        if (!(platform.key in content.platforms)) {
            throw new Error(`Missing localized website download content for ${platform.key}`);
        }

        const key = platform.key as DownloadPlatformKey;
        const platformContent = content.platforms[key];

        return {
            ...platform,
            key,
            content: platformContent,
        };
    });

    return {
        ...catalog,
        content: channelContent,
        platforms,
    };
});
---

<section
    class="download-section large-padding"
    id="download-options"
    aria-labelledby="download-options-title"
>
    <div class="center-align">
        <h1 class="large-title" id="download-options-title">{content.sectionTitle}</h1>
        <p class="max-width-60">{content.sectionDescription}</p>
    </div>

    <div class="download-channel-list">
        {catalogs.map((catalog) => {
            const channelTitleId = `download-channel-${catalog.channel}-title`;
            const channelVersion = formatMessage(content.channelVersion, {
                channel: catalog.content.name,
                version: catalog.version,
            });
            const releasePageLabel = formatMessage(content.releasePage, {
                channel: catalog.content.name,
                version: catalog.version,
            });
            const channelNotice = catalog.releasePageOnly
                ? content.stableReleaseOnly
                : !catalog.hasDownloads ? content.betaCanonicalUnavailable : null;

            return (
                <section
                    class="download-channel round large-padding surface-container-low"
                    aria-labelledby={channelTitleId}
                    data-download-channel-section={catalog.channel}
                    data-download-channel-version={catalog.version}
                    data-download-channel-has-downloads={String(catalog.hasDownloads)}
                >
                    <div class="row wrap middle-align">
                        <div class="max">
                            <div class="row wrap middle-align">
                                <h3 id={channelTitleId}>{catalog.content.name}</h3>
                            </div>
                            <p class="small-text bold primary-text">{channelVersion}</p>
                            <p>{catalog.content.description}</p>
                            {channelNotice && (
                                <p class="download-channel-notice secondary-container" data-download-channel-notice>
                                    <i aria-hidden="true">info</i>
                                    <span>{channelNotice}</span>
                                </p>
                            )}
                        </div>
                    </div>

                    {catalog.platforms.length > 0 && (
                        <div class="download-platform-grid">
                        {catalog.platforms.map((platform) => {
                            const descriptionId = `download-platform-${catalog.channel}-${platform.key}-description`;
                            const availableDownloads = platform.downloads.filter((download) => download.url);

                            return (
                                <article
                                    class="download-platform-card no-margin round large-padding surface-container"
                                    data-download-channel={catalog.channel}
                                    data-download-platform-card={platform.key}
                                    data-download-platform-emphasis-candidate={
                                        catalog.channel === siteConfig.stableRelease.channel
                                            ? ""
                                            : undefined
                                    }
                                >
                                    <h4>{platform.operatingSystem}</h4>
                                    <div
                                        class="download-platform-brand round surface-container-highest"
                                        aria-hidden="true"
                                    >
                                        <PlatformBrandIcon operatingSystem={platform.operatingSystem} />
                                    </div>
                                    <p id={descriptionId}>{platform.content.description}</p>

                                    {platform.available ? (
                                        <div class="download-actions">
                                            {availableDownloads.map((download) => {
                                                const format = content.formats[download.id]
                                                    ?? download.format.toUpperCase();
                                                const actionLabel = formatMessage(content.downloadAction, {
                                                    channel: catalog.content.name,
                                                    version: catalog.version,
                                                    platform: platform.content.name,
                                                    format,
                                                });

                                                return (
                                                    <a
                                                        class:list={[
                                                            "button large round responsive",
                                                            download.primary
                                                                ? "primary-container"
                                                                : "secondary-container",
                                                        ]}
                                                        href={download.url ?? undefined}
                                                        aria-label={actionLabel}
                                                        aria-describedby={descriptionId}
                                                        data-download-link
                                                        data-download-channel={catalog.channel}
                                                        data-download-platform={platform.key}
                                                        data-download-action-label={actionLabel}
                                                    >
                                                        <i aria-hidden="true">download</i>
                                                        <span>{format}</span>
                                                    </a>
                                                );
                                            })}
                                        </div>
                                    ) : (
                                        <p class="download-unavailable secondary-text" data-download-unavailable>
                                            <i aria-hidden="true">schedule</i>
                                            <span>{content.unavailable}</span>
                                        </p>
                                    )}
                                </article>
                            );
                        })}
                        </div>
                    )}

                    <div class="center-align">
                        <a
                            class="button round border"
                            href={catalog.releaseUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            data-download-release-link={catalog.channel}
                        >
                            <i aria-hidden="true">open_in_new</i>
                            <span>{releasePageLabel}</span>
                        </a>
                    </div>
                </section>
            );
        })}
    </div>
</section>

<script>
    type NavigatorWithUserAgentData = Navigator & {
        userAgentData?: {
            platform?: string;
        };
    };

    function detectDownloadPlatform(): string | null {
        const browserNavigator = navigator as NavigatorWithUserAgentData;
        const platform = (
            browserNavigator.userAgentData?.platform
            || navigator.platform
            || ""
        ).toLowerCase();
        const userAgent = navigator.userAgent.toLowerCase();
        const platformAndUserAgent = `${platform} ${userAgent}`;

        if (
            platformAndUserAgent.includes("android")
            || platformAndUserAgent.includes("chrome os")
            || platformAndUserAgent.includes("cros")
            || platformAndUserAgent.includes("iphone")
            || platformAndUserAgent.includes("ipad")
            || platformAndUserAgent.includes("ipod")
            || (
                platform.includes("macintel")
                && navigator.maxTouchPoints > 1
            )
        ) {
            return null;
        }

        if (
            platform.includes("windows")
            || platform.includes("win32")
            || platform.includes("win64")
            || (!platform && userAgent.includes("windows"))
        ) {
            return "windows-x86_64";
        }
        if (
            platform.includes("macos")
            || platform.includes("macintosh")
            || platform.includes("macintel")
            || (!platform && userAgent.includes("macintosh"))
        ) {
            return "darwin-aarch64";
        }
        if (
            platform.includes("linux")
            || platform.includes("x11")
            || (!platform && (userAgent.includes("linux") || userAgent.includes("x11")))
        ) {
            return "linux-x86_64";
        }

        return null;
    }

    function applyDownloadPlatformMatch() {
        const platformKey = detectDownloadPlatform();
        const cards = Array.from(document.querySelectorAll<HTMLElement>(
            "[data-download-platform-card]",
        ));

        for (const card of cards) {
            card.removeAttribute("aria-current");
            card.removeAttribute("data-download-platform-match");
        }

        if (!platformKey) {
            return;
        }

        const matchingStableCard = cards.find((card) => (
            card.hasAttribute("data-download-platform-emphasis-candidate")
            && card.dataset.downloadPlatformCard === platformKey
        ));

        if (!matchingStableCard) {
            return;
        }

        matchingStableCard.setAttribute("aria-current", "true");
        matchingStableCard.setAttribute("data-download-platform-match", "");
    }

    applyDownloadPlatformMatch();
</script>
