---
import { siteConfig, type LocaleContent } from "@/data/site";

type Props = {
    locale: LocaleContent;
};

const { locale } = Astro.props;
---

<div
    data-contributors-section
    data-contributors-api-url={siteConfig.contributorsApiUrl}
    hidden
>
    <div class="large-divider"></div>
    <section class="large-padding center-align" aria-labelledby="contributors-title">
        <h2 class="large-title" id="contributors-title">{locale.contributorsTitle}</h2>
        <div class="space"></div>
        <div class="row wrap center-align middle-align small-space" data-contributors-list>
        </div>
    </section>
</div>

<script>
    type Contributor = {
        avatarUrl: string;
        name: string;
        profileUrl: string;
    };

    function isHttpsUrl(value: unknown): value is string {
        if (typeof value !== "string") {
            return false;
        }

        try {
            return new URL(value).protocol === "https:";
        } catch {
            return false;
        }
    }

    function normalizeContributor(value: unknown): Contributor | null {
        if (
            typeof value !== "object"
            || value === null
            || !("login" in value)
            || !("avatar_url" in value)
            || !("html_url" in value)
            || typeof value.login !== "string"
            || value.login.length === 0
            || !isHttpsUrl(value.avatar_url)
            || !isHttpsUrl(value.html_url)
        ) {
            return null;
        }

        return {
            avatarUrl: value.avatar_url,
            name: value.login,
            profileUrl: value.html_url,
        };
    }

    function createContributorLink(contributor: Contributor) {
        const link = document.createElement("a");
        const image = document.createElement("img");
        const tooltip = document.createElement("div");

        link.className = "no-wave";
        link.href = contributor.profileUrl;
        link.target = "_blank";
        link.rel = "noopener noreferrer";
        link.referrerPolicy = "no-referrer";
        link.ariaLabel = contributor.name;
        link.title = contributor.name;
        link.dataset.contributorLink = "";

        image.className = "large circle border";
        image.src = contributor.avatarUrl;
        image.alt = "";
        image.width = 56;
        image.height = 56;
        image.loading = "lazy";
        image.decoding = "async";
        image.referrerPolicy = "no-referrer";

        tooltip.className = "tooltip";
        tooltip.textContent = contributor.name;

        link.append(image, tooltip);

        return link;
    }

    async function fetchContributors(
        apiUrl: string,
    ) {
        const response = await fetch(apiUrl, {
            headers: {
                Accept: "application/vnd.github+json",
            },
        });
        if (!response.ok) {
            throw new Error(`ALCOMD3 contributors request failed: ${response.status}`);
        }

        const responseData = await response.json() as unknown;
        if (!Array.isArray(responseData)) {
            throw new Error("ALCOMD3 contributors response is invalid");
        }

        return responseData
            .map(normalizeContributor)
            .filter((contributor): contributor is Contributor => contributor !== null);
    }

    document.querySelectorAll<HTMLElement>("[data-contributors-section]").forEach((section) => {
        const apiUrl = section.dataset.contributorsApiUrl;
        const list = section.querySelector<HTMLElement>("[data-contributors-list]");

        if (!apiUrl || !list) {
            return;
        }

        fetchContributors(apiUrl)
            .then((contributors) => {
                if (contributors.length === 0) {
                    return;
                }

                list.replaceChildren(...contributors.map(createContributorLink));
                section.hidden = false;
                section.dataset.contributorsLive = "";
            })
            .catch((error) => {
                console.warn("Failed to load ALCOMD3 contributors from GitHub.", error);
            });
    });
</script>
