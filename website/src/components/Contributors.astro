---
import { siteConfig, type LocaleContent } from "@/data/site";
import contributorSnapshot from "../../../generated/alcomd3-contributors.json";

type Props = {
    locale: LocaleContent;
};

const { locale } = Astro.props;
const bundledContributors = contributorSnapshot.contributors;
---

<div
    data-contributors-section
    data-contributors-api-url={siteConfig.contributorsApiUrl}
    data-contributors-repository={contributorSnapshot.repository}
    data-contributors-source={bundledContributors.length > 0 ? "snapshot" : undefined}
    hidden={bundledContributors.length === 0}
>
    <div class="large-divider"></div>
    <section class="large-padding center-align" aria-labelledby="contributors-title">
        <h2 class="large-title" id="contributors-title">{locale.contributorsTitle}</h2>
        <div class="space"></div>
        <div class="row wrap center-align middle-align small-space" data-contributors-list>
            {bundledContributors.map((contributor) => (
                <a
                    aria-label={contributor.name}
                    class="no-wave"
                    data-contributor-link
                    href={contributor.profileUrl}
                    referrerpolicy="no-referrer"
                    rel="noopener noreferrer"
                    target="_blank"
                    title={contributor.name}
                >
                    <img
                        alt=""
                        class="large circle border"
                        decoding="async"
                        height="56"
                        loading="lazy"
                        referrerpolicy="no-referrer"
                        src={contributor.avatarUrl}
                        width="56"
                    />
                    <div class="tooltip">{contributor.name}</div>
                </a>
            ))}
        </div>
    </section>
</div>

<script>
    type Contributor = {
        avatarUrl: string;
        name: string;
        profileUrl: string;
    };

    type ContributorsResponse = {
        contributors?: unknown;
        repository?: unknown;
        schemaVersion?: unknown;
    };

    function isHttpsUrl(value: unknown): value is string {
        if (typeof value !== "string") {
            return false;
        }

        try {
            return new URL(value).protocol === "https:";
        } catch {
            return false;
        }
    }

    function normalizeContributor(value: unknown): Contributor | null {
        if (
            typeof value !== "object"
            || value === null
            || !("name" in value)
            || !("avatarUrl" in value)
            || !("profileUrl" in value)
            || typeof value.name !== "string"
            || value.name.length === 0
            || !isHttpsUrl(value.avatarUrl)
            || !isHttpsUrl(value.profileUrl)
        ) {
            return null;
        }

        return {
            avatarUrl: value.avatarUrl,
            name: value.name,
            profileUrl: value.profileUrl,
        };
    }

    function createContributorLink(contributor: Contributor) {
        const link = document.createElement("a");
        const image = document.createElement("img");
        const tooltip = document.createElement("div");

        link.className = "no-wave";
        link.href = contributor.profileUrl;
        link.target = "_blank";
        link.rel = "noopener noreferrer";
        link.referrerPolicy = "no-referrer";
        link.ariaLabel = contributor.name;
        link.title = contributor.name;
        link.dataset.contributorLink = "";

        image.className = "large circle border";
        image.src = contributor.avatarUrl;
        image.alt = "";
        image.width = 56;
        image.height = 56;
        image.loading = "lazy";
        image.decoding = "async";
        image.referrerPolicy = "no-referrer";

        tooltip.className = "tooltip";
        tooltip.textContent = contributor.name;

        link.append(image, tooltip);

        return link;
    }

    async function fetchContributors(
        apiUrl: string,
        repository: string,
    ) {
        const response = await fetch(apiUrl, {
            headers: {
                Accept: "application/json",
            },
        });
        if (!response.ok) {
            throw new Error(`ALCOMD3 contributors request failed: ${response.status}`);
        }

        const responseData = await response.json() as ContributorsResponse;
        if (
            responseData.schemaVersion !== 1
            || responseData.repository !== repository
            || !Array.isArray(responseData.contributors)
        ) {
            throw new Error("ALCOMD3 contributors response is invalid");
        }

        const contributors = responseData.contributors.map(normalizeContributor);
        if (
            contributors.length === 0
            || contributors.some((contributor) => contributor === null)
        ) {
            throw new Error("ALCOMD3 contributors response is invalid");
        }

        const validContributors = contributors as Contributor[];
        const profileUrls = new Set(
            validContributors.map((contributor) => contributor.profileUrl),
        );
        if (profileUrls.size !== validContributors.length) {
            throw new Error("ALCOMD3 contributors response is invalid");
        }

        return validContributors;
    }

    document.querySelectorAll<HTMLElement>("[data-contributors-section]").forEach((section) => {
        const apiUrl = section.dataset.contributorsApiUrl;
        const repository = section.dataset.contributorsRepository;
        const list = section.querySelector<HTMLElement>("[data-contributors-list]");

        if (!apiUrl || !repository || !list) {
            return;
        }

        fetchContributors(apiUrl, repository)
            .then((contributors) => {
                if (contributors.length === 0) {
                    return;
                }

                list.replaceChildren(...contributors.map(createContributorLink));
                section.hidden = false;
                section.dataset.contributorsLive = "";
                section.dataset.contributorsSource = "live";
            })
            .catch((error) => {
                console.warn(
                    "Failed to refresh ALCOMD3 contributors; using the bundled build snapshot.",
                    error,
                );
            });
    });
</script>
