// Setup Page
    "setup:loading": "設定を読み込み中...",
    "setup:entry:welcome": "ようこそ！",
    "setup:entry:welcome description": "ALCOMD3はUnityプロジェクトを管理するための<br>オープンソースなCreator Companionです。",
    "setup:next": "進む",
    "setup:back": "戻る",

    "setup:steps card:Appearance": "UI設定",
    "setup:appearance:description": "はじめに、UIの設定を行いましょう。<br>ここで行う初期設定の内容は後からでも変えることができます。",
    "setup:steps card:LegacyImport": "インポート",
    "setup:legacy import:heading": "外部アプリからインポート",
    "setup:legacy import:description": "ALCOMD3 は独立した新しいデータディレクトリから開始します。VCC または legacy ALCOM を利用していた場合、ここで選択したデータを手動で ALCOMD3 にコピーできます。",

    "setup:steps card:UnityHub": "Unity Hubの設定",
    "setup:unity-hub:heading": "Unity Hubのインストール",
    "setup:unity-hub:description": "Unityをインストールしたり管理したりするために、Unity Hubをインストールする必要があります。<br>操作を行うために必要なUnityがインストールされていない場合、ALCOMD3はUnity Hub経由でのUnityインストールを提案します。",
    "setup:unity-hub:using this unity hub": "使用するUnity Hub",
    "setup:unity-hub:download unity hub from unity.com": "unity.comでUnity Hubをダウンロードする",
    "setup:unity-hub:unity hub link": "https://unity.com/ja/download",
    "setup:unity-hub:recheck installation": "Unity Hubの有無を再確認する",
    "setup:unity-hub:detection failed collapse": "Unity Hubがインストール済みですか？",
    "setup:unity-hub:detection failed description": "Unity Hubの有無をもう一度確認させるには、\"Unity Hubの有無を再確認する\"ボタンを押してください。これが機能しない場合、ALCOMD3はUnity Hubの検出に失敗していますので、手動でUnity Hubの場所を指定してください。",
    "setup:unity-hub:not found": "Unity Hubが見つかりませんでした。",

    "setup:steps card:ProjectPath": "保存先の設定",
    "setup:project-path:heading": "プロジェクト作成時の保存先",
    "setup:project-path:description": "ALCOMD3でプロジェクトを作成する場合、プロジェクトはこの場所に保存されます。",

    "setup:steps card:Backups": "バックアップ設定",
    "setup:backups:heading": "バックアップの設定",
    "setup:backups:location": "バックアップの保存先",
    "setup:backups:location description": "ALCOMD3でプロジェクトのバックアップを作成する場合、バックアップファイルはこの場所に保存されます。",
    "setup:backups:archive": "バックアップの保存形式",

    "setup:steps card:SystemSetting": "システム設定",
    "setup:system-setting:heading": "システム設定",
    "setup:system-setting:vcc scheme description": "<code>vcc:</code>から始まるURLは、ブラウザからVCCを起動してVPMリポジトリを追加するためのリンクです。<br>ALCOMD3とVCCはリポジトリ一覧を共有していますが、ALCOMD3を <code>vcc:</code> URLと紐付けることで、ブラウザからALCOMD3を起動してVPMリポジトリを追加することができるようになります。",
    "setup:system-setting:macos bug message": "macOS向けの設定項目は特にありません。<br>(このページは表示されないはずなので、表示されている場合はバグです)",
    "setup:system-setting:hostname-with-non-ascii": "PC名(ホスト名)に非ASCII文字(半角英数字や半角記号等ではない文字)が使用されています。<br>これはUnityで問題を引き起こす場合があります。<br>半角英数字のPC名(ホスト名)に変更することを強くお勧めします。",

    "setup:finish:heading": "初期設定が完了しました！",
    "setup:finish:description": "ALCOMD3を使うための準備がすべて終わりました！",
    "setup:finish:next": "ALCOMD3を使い始める",


